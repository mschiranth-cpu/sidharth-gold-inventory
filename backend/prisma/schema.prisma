  givenDate         DateTime @map("given_date")
  deductionPerMonth Float    @map("deduction_per_month")
  totalDeducted     Float    @default(0) @map("total_deducted")
  remainingAmount   Float    @map("remaining_amount")
  status            String   @default("ACTIVE")
  approvedById      String?  @map("approved_by_id")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  @@index([userId])
  @@index([status])
  @@map("employee_advances")
}

model EmployeeLoan {
  id              String   @id @default(uuid())
  userId          String   @map("user_id")
  user            User     @relation("EmployeeLoans", fields: [userId], references: [id], onDelete: Cascade)
  loanAmount      Float    @map("loan_amount")
  interestRate    Float?   @map("interest_rate")
  tenure          Int
  emiAmount       Float    @map("emi_amount")
  disbursedDate   DateTime @map("disbursed_date")
  startMonth      DateTime @map("start_month")
  totalPaid       Float    @default(0) @map("total_paid")
  remainingAmount Float    @map("remaining_amount")
  status          String   @default("ACTIVE")
  approvedById    String?  @map("approved_by_id")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@index([userId])
  @@index([status])
  @@map("employee_loans")
}

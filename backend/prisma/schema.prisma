  meltedAt         DateTime  @map("melted_at")
  notes            String?
  createdAt        DateTime  @default(now()) @map("created_at")

  transactions MetalTransaction[]

  @@index([batchNumber])
  @@index([meltedAt])
  @@map("melting_batches")
}

model MetalRate {
  id            String    @id @default(uuid())
  metalType     MetalType @map("metal_type")
  purity        Float
  ratePerGram   Float     @map("rate_per_gram")
  effectiveDate DateTime  @map("effective_date")
  source        String?
  createdById   String    @map("created_by_id")
  createdBy     User      @relation("MetalRatesCreated", fields: [createdById], references: [id])
  createdAt     DateTime  @default(now()) @map("created_at")

  @@index([metalType])
  @@index([effectiveDate])
  @@index([metalType, purity, effectiveDate])
  @@map("metal_rates")
}

